APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001","http://localhost:3002","http://127.0.0.1:3002"]
STORAGE_ROOT=../storage
MAX_DURATION_SECONDS=600
MAX_UPLOAD_SIZE_BYTES=83886080
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
DEMUCS_COMMAND=demucs
DEMUCS_MODEL=htdemucs
SOME_ENABLED=true
SOME_REPO_PATH=/absolute/path/to/openvpi/SOME
SOME_MODEL_PATH=/absolute/path/to/some-model/config-and-ckpt/model_ckpt_steps_100000_simplified.ckpt
SOME_PYTHON_BIN=/absolute/path/to/openvpi/SOME/.venv/bin/python
BASIC_PITCH_ENABLED=true
FLUIDSYNTH_BIN=fluidsynth
SOUNDFONT_PATH=/absolute/path/to/GeneralUser_GS.sf2
NORMALIZED_SAMPLE_RATE=44100
MIDI_MIN_NOTE_MS=45
MIDI_MERGE_GAP_MS=20
MIDI_QUANTIZE_MS=5
MIDI_OCTAVE_SNAP_ENABLED=true
MIDI_OCTAVE_SNAP_JUMP_SEMITONES=8
MIDI_TARGET_PITCH_MIN=48
MIDI_TARGET_PITCH_MAX=76
PREVIEW_MIX_ACCOMPANIMENT_GAIN=0.72
PREVIEW_MIX_KEYS_GAIN=1.35
